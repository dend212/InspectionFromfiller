# Supabase Configuration
# Get these from: Supabase Dashboard -> Project Settings -> API

# Project URL (e.g., https://abcdefghij.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# anon/public key (safe for browser)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# service_role key (SERVER-ONLY -- never expose in client code)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database connection string
# Get from: Supabase Dashboard -> Project Settings -> Database -> Connection string
# Use Transaction pooler (port 6543) -- NOT the direct connection (port 5432)
# which may be IPv6-only and unreachable from local networks
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Workiz webhook integration (n8n -> app)
# Generate with: openssl rand -hex 32
WORKIZ_WEBHOOK_SECRET=your-webhook-secret-here
# Workiz API secret (for n8n to call Workiz API)
WORKIZ_API_SECRET=your-workiz-api-secret
WORKIZ_API_TOKEN=your-workiz-api-token

# n8n Jobs webhook — used by /api/webhooks/jobs/* (Workiz -> n8n -> this app)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
JOBS_WEBHOOK_SECRET=your-jobs-webhook-secret-here

# Anthropic API (AI-powered form scan)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key
